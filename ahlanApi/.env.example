# =============================================================================
# Ahlan API — Production .env (serverda ushbu faylni .env nomiga nusxalang)
# =============================================================================

# --- MAJBURIY (Production) ---
# Django maxfiy kalit — 50+ belgi, har doim o'zingiz yarating va hech kimga bermang.
# Misol: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=o'zgartiring-50-belgidan-uzun-maxfiy-kalit-bu-misol-uchun

# Production da har doim False. True faqat ishlab chiqishda.
DJANGO_DEBUG=False

# Server domenlari va IP — vergul bilan, bo'shliqsiz. So'rovlar faqat shu hostlar uchun qabul qilinadi.
DJANGO_ALLOWED_HOSTS=ahlan.uz,www.ahlan.uz,api.ahlan.uz,64.226.109.56,localhost,127.0.0.1,ahlanhouse

# --- Ixtiyoriy ---
# Ma'lumotlar bazasi: default db.sqlite3 (ahlanApi papkasida). O'zgartirmasangiz env kerak emas.
# PostgreSQL uchun (kelajakda): DATABASE_URL=postgres://user:pass@localhost:5432/ahlan_db

# Fayl yuklash limiti settings.py da 10 MB (DATA_UPLOAD_MAX_MEMORY_SIZE). O'zgartirmoqchi bo'lsangiz settings.py ni tahrirlang.

# =============================================================================
# Nusxalash: cp .env.example .env   keyin  nano .env  bilan DJANGO_SECRET_KEY ni albatta o'zgartiring.
# =============================================================================
